# GOOGLE_CLOUD_PROJECT: The Google Cloud project ID for Vertex AI clients.
# Required if not provided dynamically in the UI.
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"

# SERVER_PORT: Custom port to run the server on (default: 3000)
SERVER_PORT=3000

# GOOGLE_GENAI_USE_ENTERPRISE: Set to True to enable Vertex AI Enterprise features
GOOGLE_GENAI_USE_ENTERPRISE=True

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
